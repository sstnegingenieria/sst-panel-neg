rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────────
    // HELPERS
    // ────────────────────────────────────────────────────────────────

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAuthed() {
      return request.auth != null;
    }

    // Lee el rol del usuario, con fallback al campo legacy 'role'
    // (H-002 cerrado en datos, fallback cosmético pendiente).
    function rolActual() {
      return userData().get('rol', userData().get('role', ''));
    }

    // 1. Cualquier rol con acceso al panel web (lectura general de users)
    function esPersonalPanel() {
      return isAuthed() && rolActual() in [
        'sst', 'admin',
        'gerencia_general', 'gerencia_administrativa',
        'operacion_comercial', 'auxiliar_proyectos', 'director_proyectos',
        'residente_sst', 'gestion_integral'
      ];
    }

    // 2. Roles que administran obras y contratistas (crear/editar).
    function puedeGestionarProyectos() {
      return isAuthed() && rolActual() in [
        'admin',
        'gerencia_general',
        'operacion_comercial', 'auxiliar_proyectos', 'director_proyectos'
      ];
    }

    // 3. Administración del subsistema SST (aprobar/rechazar formularios,
    //    gestionar users). Reemplaza el viejo isSST() ampliado con
    //    gestion_integral.
    function puedeAdministrarSST() {
      return isAuthed() && rolActual() in [
        'sst', 'admin', 'gestion_integral'
      ];
    }

    // 4. Solo lectura del subsistema SST (gerencia_general con visión
    //    ejecutiva total)
    function puedeVerSSTSoloLectura() {
      return isAuthed() && rolActual() in ['gerencia_general'];
    }

    // 5. Acceso al módulo SIGP (lectura de colecciones comerciales/proyectos).
    //    Espeja ROLES_CON_ACCESO_SIGP de types/sigp/roles.ts.
    function accesoSIGP() {
      return isAuthed() && rolActual() in [
        'admin', 'gerencia_general', 'gerencia_administrativa',
        'operacion_comercial', 'director_proyectos', 'auxiliar_proyectos',
        'gestion_integral'
      ];
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: users
    // ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Read: uno mismo, o cualquier rol con acceso al panel
      allow read: if isAuthed() && (
        request.auth.uid == userId || esPersonalPanel()
      );

      // Update self: puede editar su propio documento, pero NO cambiar
      // campos sensibles.
      allow update: if isAuthed()
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasAny(['rol', 'role', 'estado', 'aprobado', 'obras_asignadas']);

      // Create/update/delete administrativo: solo puedeAdministrarSST
      allow create, update, delete: if puedeAdministrarSST();

      // Create self: al registrarse en la app, no puede autoasignarse
      // rol sst/admin
      allow create: if isAuthed()
                    && request.auth.uid == userId
                    && !(request.resource.data.get('rol', '') in ['sst', 'admin'])
                    && !(request.resource.data.get('role', '') in ['sst', 'admin']);
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: obras
    // ────────────────────────────────────────────────────────────────

    match /obras/{obraId} {
      // Read: cualquier usuario autenticado (comportamiento legacy). El panel
      // SST (hub de registros) y la app Flutter necesitan listar obras.
      allow read: if isAuthed();

      // Write: solo gestión de proyectos (incluye `sst` para retrocompat)
      allow create, update, delete: if puedeGestionarProyectos();
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: contratistas
    // ────────────────────────────────────────────────────────────────
    // Lectura pública justificada: el formulario de registro de
    // técnicos en la app SST necesita listar contratistas pre-login.
    // Solo se expone el nombre del contratista; NIT/cédula/teléfono/
    // dirección están cubiertos por seguridad en Firestore Rules
    // (documentos con campos protegidos). Ver H-001 (severidad bajada
    // a Baja tras validación del caso de uso).

    match /contratistas/{contratistaId} {
      allow read: if true;

      // Gestión completa (crear/editar/eliminar).
      allow create, update, delete: if puedeGestionarProyectos();

      // gerencia_administrativa: habilitar/deshabilitar contratistas. SOLO puede
      // cambiar el campo `estado`. El panel (useFirestore) inyecta
      // `fecha_actualizacion` en cada update, así que se permite junto a `estado`.
      // No puede crear ni eliminar ni tocar ningún otro campo.
      allow update: if isAuthed()
                    && rolActual() == 'gerencia_administrativa'
                    && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['estado', 'fecha_actualizacion']);
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: registros — INMUTABLE (auditoría a prueba de manipulación)
    // ────────────────────────────────────────────────────────────────

    match /registros/{registroId} {
      allow read: if isAuthed() && (
        puedeAdministrarSST() ||
        puedeVerSSTSoloLectura() ||
        resource.data.get('tecnicoId', '') == request.auth.uid
      );
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: formularios
    // ────────────────────────────────────────────────────────────────

    match /formularios/{formularioId} {
      allow read: if isAuthed() && (
        puedeAdministrarSST() ||
        puedeVerSSTSoloLectura() ||
        resource.data.get('user_id', '') == request.auth.uid
      );

      allow create: if isAuthed() &&
        request.resource.data.get('user_id', '') == request.auth.uid;

      allow update: if isAuthed() && (
        puedeAdministrarSST() ||
        resource.data.get('user_id', '') == request.auth.uid
      );

      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: contadores — consecutivos atómicos SST (app móvil)
    // ────────────────────────────────────────────────────────────────
    // Sin cambio. Sistema legacy de la app Flutter.

    match /contadores/{clave} {
      allow read, create, update: if isAuthed();
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: notificaciones — panel SST ↔ app móvil
    // ────────────────────────────────────────────────────────────────

    match /notificaciones/{notifId} {
      allow read: if isAuthed() && (
        puedeAdministrarSST() ||
        puedeVerSSTSoloLectura() ||
        resource.data.get('user_id', '') == request.auth.uid
      );

      allow create: if isAuthed();

      allow update: if isAuthed() && (
        puedeAdministrarSST() ||
        resource.data.get('user_id', '') == request.auth.uid
      );

      allow delete: if puedeAdministrarSST();
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: clientes (SIGP — Comercial, F1)
    // ────────────────────────────────────────────────────────────────
    // Read: cualquier rol con acceso al módulo SIGP.
    // Write: solo roles que gestionan proyectos/comercial.

    match /clientes/{clienteId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: lpus (+ subcolección items) — SIGP, Comercial, F1
    // ────────────────────────────────────────────────────────────────
    // Read: cualquier rol con acceso SIGP. Write: gestión de proyectos.
    // Los ítems (~900 por LPU) viven en la subcolección lpus/{id}/items.

    match /lpus/{lpuId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();

      match /items/{itemId} {
        allow read: if accesoSIGP();
        allow create, update, delete: if puedeGestionarProyectos();
      }
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: solicitudes (SIGP — Comercial, F1)
    // ────────────────────────────────────────────────────────────────
    // Bandeja de entrada comercial. Read: acceso SIGP. Write: gestión de proyectos.

    match /solicitudes/{solicitudId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: visitas (SIGP — Comercial, F1 — levantamiento)
    // ────────────────────────────────────────────────────────────────
    // Read: acceso SIGP. Write: gestión de proyectos.

    match /visitas/{visitaId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: cotizaciones (+ subcolección versiones) — SIGP, Comercial, F1
    // ────────────────────────────────────────────────────────────────
    // Read: acceso SIGP. Write: gestión de proyectos. Cada versión (snapshot con
    // ítems inline) vive en la subcolección cotizaciones/{id}/versiones.

    match /cotizaciones/{cotizacionId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();

      match /versiones/{versionId} {
        allow read: if accesoSIGP();
        allow create, update, delete: if puedeGestionarProyectos();
      }
    }

    // ────────────────────────────────────────────────────────────────
    // COLECCIÓN: catalogo_items — catálogo NEG de ítems propios (F1.4-B)
    // ────────────────────────────────────────────────────────────────
    // Read: acceso SIGP. Write: gestión de proyectos. El código CAT-NNNN lo
    // genera la Cloud Function generarConsecutivo (contador acumulativo).

    match /catalogo_items/{itemId} {
      allow read: if accesoSIGP();
      allow create, update, delete: if puedeGestionarProyectos();
    }

    // ────────────────────────────────────────────────────────────────
    // CATCH-ALL: denegar todo lo no especificado explícitamente
    // ────────────────────────────────────────────────────────────────
    // Incluye la colección `consecutivos` del SIGP: solo la Cloud
    // Function `generarConsecutivo` con Admin SDK puede leerla/escribirla.

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
