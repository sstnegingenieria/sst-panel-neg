rules_version = '2';

// Reglas de producción de Firebase Storage para neg-sst-app.
// Reconstruidas desde las reglas desplegadas (bloque `pdfs/**` de la app Flutter)
// + el bloque `lpus/**` del SIGP (F1). El bloque `pdfs/**` NO se modifica.
service firebase.storage {
  match /b/{bucket}/o {

    // ── App SST (Flutter): PDFs de formularios. Sin cambio. ──────────────────
    match /pdfs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── SIGP (F1): Excel original de cada LPU ────────────────────────────────
    // Ruta: lpus/{clienteId}/{lpuId}/{archivo}
    // La autorización real (quién puede crear/versionar una LPU) la impone
    // Firestore sobre el doc `lpus` (puedeGestionarProyectos). Aquí basta
    // autenticación: un Excel huérfano en Storage, sin su doc LPU, es
    // inofensivo (no expone precios).
    //
    // Nota: se intentó gatear el write por rol vía cross-service rules
    // (firestore.get sobre users/{uid}.rol), pero denegaba en runtime pese a
    // rol válido (feature poco fiable). Queda como posible hardening futuro.
    match /lpus/{clienteId}/{lpuId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // ── SIGP (F1): adjuntos de solicitudes ───────────────────────────────────
    // Ruta: solicitudes/{solicitudId}/{archivo}. Mismo patrón final que LPU
    // (auth-only; el gate por rol vía cross-service quedó como hardening, H-008).
    match /solicitudes/{solicitudId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // ── SIGP (F1): fotos/planos de visitas técnicas ──────────────────────────
    // Ruta: visitas/{visitaId}/**. Auth-only (patrón final de LPU, H-008).
    match /visitas/{visitaId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── SIGP (F1): evidencia de aprobación / doc de licitación de cotizaciones ─
    // Ruta: cotizaciones/{cotizacionId}/**. Auth-only (patrón final de LPU, H-008).
    match /cotizaciones/{cotizacionId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
