VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Override de feature flags SOLO en desarrollo (opcional) ───────────────────
# En dev (import.meta.env.DEV), useFeatureFlag lee VITE_FF_<nombre> y cortocircuita
# Remote Config. Poner en un .env.local (gitignored) para validar módulos ocultos
# sin tocar Remote Config. En build de producción el override es inerte.
# Ej: habilitar el módulo SIGP en local →
# VITE_FF_sigp_f1_enabled=true
