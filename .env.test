# Valores dummy para Firebase Emulator Suite en tests.
# NO son credenciales reales — el projectId 'demo-neg' es la convención de Firebase
# para proyectos de solo-emulador (nunca contacta servicios reales).
#
# Vite/Vitest cargan este archivo solo en modo test (no en dev ni build).
# En modo test, firebase/config.ts conecta auth/db/storage/functions a los
# emuladores locales (127.0.0.1), así que estos valores nunca salen a la red.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_PROJECT_ID=demo-neg
VITE_FIREBASE_AUTH_DOMAIN=demo-neg.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=demo-neg.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=demo-app-id
